{
  "manifest_version": 3,
  "name": "__MSG_pluginName__",
  "description": "__MSG_pluginDesc__",
  "version": "1.0.0",
  "action": {
    "default_title": "__MSG_pluginName__"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["*://gemini.google.com/*", "*://www.doubao.com/*", "*://chatgpt.com/*", "*://chat.deepseek.com/*",
      "*://yuanbao.tencent.com/*", "*://www.qianwen.com/*"],
      "js": ["src/content/index.ts"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "default_locale": "en"
}